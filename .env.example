BRANCH_NAME=main

# API key pro:
GOOGLE_API_KEY=

GROQ_API_KEY=

# Database Configuration
DATABASE_URL=postgresql://chatbot_user:chatbot_pass_2024@postgres:5432/chatbot_db
POSTGRES_PASSWORD=chatbot_pass_2024

# -----------------------------------------------------------------------------
# Qdrant Vector Database
# -----------------------------------------------------------------------------
# For Docker: use service name
QDRANT_URL=http://qdrant:6333
# For local development: use localhost
# QDRANT_URL=http://localhost:6333

QDRANT_COLLECTION=documents

# -----------------------------------------------------------------------------
# Embedding Model Configuration
# -----------------------------------------------------------------------------
EMBEDDING_BATCH_SIZE=32

# -----------------------------------------------------------------------------
# Optional: Model paths (auto-detected if not set)
# -----------------------------------------------------------------------------
# MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# MODEL_DIR=/app/models
# HF_HOME=/hf_cache

# # LLM Settings GGUF
# LLM_MODEL=qwen2.5-3b-q4
# LLM_TEMPERATURE=0.7
# LLM_MAX_OUTPUT_TOKENS=1024

# # LLM_MODEL=Qwen2.5-3B-Instruct
# LLM_MODEL=qwen-7b
# LLM_TEMPERATURE=0.7
# LLM_MAX_OUTPUT_TOKENS=2048

# # llama.cpp CPU threads (điều chỉnh theo server)
# LLAMA_THREADS=4

# REMOTE_LLM_URL=https://charismatic-debora-sparkily.ngrok-free.dev

# LLM Configuration
LLM_MODEL=qwen3-8b              # Options: gemini, qwen2-7b, llama3-8b, mistral-7b
LLM_PROXY_URL=http://llm_proxy:5000  # Proxy URL (Docker) or http://localhost:5000 (local)
LLM_TEMPERATURE=0.7
LLM_MAX_OUTPUT_TOKENS=2048
LLM_PRESENCE_PENALTY=1.5

VLLM_MODEL_NAME=Qwen/Qwen3-8B-AWQ


# Hybrid Retrieval + Reranker (CPU-friendly defaults)
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_EMBEDDING_LOCAL_PATH=/app/models/bge-m3
RAG_HYBRID_TOP_K=12
RAG_DENSE_TOP_K=12
RAG_BM25_TOP_K=12
RAG_HYBRID_ALPHA=0.7
RAG_HYBRID_BETA=0.3
RAG_DENSE_SCORE_THRESHOLD=0.2

# Keep bge-reranker-v2-m3 for quality, or switch to lightweight for speed:
# RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
# RAG_RERANKER_LOCAL_PATH=/app/models/cross-encoder-ms-marco-MiniLM-L-6-v2
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

RAG_RERANK_BACKEND=openvino
RAG_RERANK_FALLBACK_BACKENDS=onnx,torch
RAG_RERANK_TOP_N=8
RAG_RERANK_BATCH_SIZE=8
RAG_RERANK_CANDIDATE_CAP=12

RAG_BM25_KEYWORD_BOOST=3       # repeat keyword tokens N times
RAG_BM25_TOPIC_BOOST=2         # repeat topic tokens N times  
RAG_RERANK_KEYWORD_BOOST=0.05  # per-keyword additive boost
RAG_RERANK_TOPIC_BOOST=0.10    # topic match additive boost
RAG_CONTEXT_INCLUDE_METADATA=true  # bật/tắt metadata hint cho LLM