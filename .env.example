GOOGLE_API_KEY=

# Database Configuration
DATABASE_URL=
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# Qdrant Vector Database
# -----------------------------------------------------------------------------
# For Docker: use service name

# Hybrid Retrieval + Reranker (CPU-friendly defaults)
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_EMBEDDING_LOCAL_PATH=/app/models/bge-m3
RAG_HYBRID_TOP_K=12
RAG_DENSE_TOP_K=12
RAG_BM25_TOP_K=12
RAG_HYBRID_ALPHA=0.7
RAG_HYBRID_BETA=0.3
RAG_DENSE_SCORE_THRESHOLD=0.2

# Keep bge-reranker-v2-m3 for quality, or switch to lightweight for speed:
# RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANK_TOP_N=5
RAG_RERANK_BATCH_SIZE=4
QDRANT_URL=http://qdrant:6333
# For local development: use localhost
# QDRANT_URL=http://localhost:6333

QDRANT_COLLECTION=documents

# -----------------------------------------------------------------------------
# Embedding Model Configuration
# -----------------------------------------------------------------------------
EMBEDDING_BATCH_SIZE=32

# -----------------------------------------------------------------------------
# Optional: Model paths (auto-detected if not set)
# -----------------------------------------------------------------------------
# MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# MODEL_DIR=/app/models
# HF_HOME=/hf_cache
# Optional: if you want to store sentence-transformers cache under /app/models
# SENTENCE_TRANSFORMERS_HOME=/app/models